# === WALLET ===
PRIVATE_KEY=your_base58_private_key_here

# === RPC ===
# Get a free API key at https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# === TRADING ===
SOL_AMOUNT=0.1
CU_LIMIT=200000
PRIORITY_FEE=100000
JITO_TIP=0.003

# === MODE ===
# DRY_RUN=true   → Build TX but do NOT send (safe for testing)
# DRY_RUN=false  → Live trading
DRY_RUN=true

# TEST_MODE=true  → Snipe ANY new Raydium AMM V4 pool (bypass Slide.fun check)
# TEST_MODE=false → Only snipe tokens graduating from Slide.fun (production)
TEST_MODE=false

# === SNIPE MODE ===
# SNIPE_MODE=raydium  → (Default) Snipe AFTER graduation to Raydium (post-migrate)
# SNIPE_MODE=slidefun → Snipe IMMEDIATELY when a new token is created on Slide.fun bonding curve
# SNIPE_MODE=both     → Run BOTH strategies in one bot (creation + graduation)
SNIPE_MODE=raydium
# Optional: override Slide.fun program ID when they migrate/deploy a new address
SLIDEFUN_PROGRAM=GkF6F9GNPjzkC18Xa3a88xwEc5vwyQDA1iXvFkKBqNDC

# SOL to spend per token in SLIDEFUN_CREATE mode (applies when SNIPE_MODE=slidefun or both)
SLIDEFUN_PUMP_AMOUNT=0.05

# === BUNDLE BUY (Multi-Wallet) ===
# Load extra sub-wallets from a JSON file for parallel bundle buying.
# See wallets.json.example for the format.
# If the file does not exist or is empty, runs in single-wallet mode only.
BUNDLE_WALLETS_FILE=wallets.json

# Amount of SOL each sub-wallet spends per token (per bundle buy)
BUNDLE_SOL_PER_WALLET=0.05
